{
  "name": "chromato",
  "version": "1.0.0",
  "description": "Focus in full colour - an animated Pomodoro timer for the terminal",
  "type": "module",
  "bin": {
    "chromato": "dist/index.js"
  },
  "scripts": {
    "build": "node build.mjs",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "pretest": "node build.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:coverage": "node build.mjs",
    "test:coverage": "vitest run --coverage",
    "cucumber": "cucumber-js --config cucumber.config.mjs",
    "test:acceptance": "cucumber-js --config cucumber.config.mjs",
    "check:arch": "dependency-cruiser src",
    "quality:gates": "pnpm check:arch && pnpm build && pnpm test && pnpm test:acceptance"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.2",
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.0.0",
    "commander": "^14.0.3",
    "ink": "^4.0.0",
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.3",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^25.8.0",
    "@types/react": "^18.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "dependency-cruiser": "^17.4.3",
    "esbuild": "^0.28.0",
    "ink-testing-library": "^4.0.0",
    "ts-node": "^10.9.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "license": "MIT",
  "author": "Giulia Mantuano",
  "homepage": "https://github.com/GiuliaMantuano/chromato#readme",
  "bugs": {
    "url": "https://github.com/GiuliaMantuano/chromato/issues"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/GiuliaMantuano/chromato"
  },
  "keywords": [
    "pomodoro",
    "timer",
    "cli",
    "tui",
    "terminal",
    "productivity"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "lodash@<4.18.0": ">=4.18.0",
      "ws@>=8.0.0 <8.20.1": ">=8.20.1",
      "vite": ">=6.4.2"
    }
  }
}
