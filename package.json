{
  "name": "chromato",
  "version": "0.1.0",
  "description": "The Pomodoro timer your terminal deserves",
  "type": "module",
  "bin": {
    "chromato": "dist/index.js"
  },
  "scripts": {
    "build": "node build.mjs",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "cucumber": "cucumber-js --config tests/acceptance/pomodoro-timer-cli/cucumber.config.ts",
    "check:arch": "dependency-cruiser src"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "dependencies": {
    "chalk": "^5.0.0",
    "commander": "^12.0.0",
    "better-sqlite3": "^9.0.0",
    "ink": "^4.0.0",
    "node-notifier": "^10.0.0",
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "dependency-cruiser": "^16.0.0",
    "esbuild": "^0.20.0",
    "ink-testing-library": "^3.0.0",
    "ts-node": "^10.9.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chromato/chromato"
  },
  "keywords": [
    "pomodoro",
    "timer",
    "cli",
    "tui",
    "terminal",
    "productivity"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
